# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=tu-clave-secreta-aqui
DEBUG=False
ALLOWED_HOSTS=tudominio.pythonanywhere.com,localhost,127.0.0.1

# ─── React embebido ───────────────────────────────────────────────────────────
# True: sirve el build de React desde / (producción en PythonAnywhere)
# False: redirige a /api/schema/swagger-ui/ (desarrollo)
EMBED_REACT=True

# ─── Email (Gmail con contraseña de aplicaciones) ─────────────────────────────
EMAIL_HOST_USER=tu@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=tu@gmail.com
CONTACT_RECIPIENT_EMAIL=tu@gmail.com

# ─── CORS (producción) ────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://tudominio.pythonanywhere.com,https://nicolasandrescl.github.io

# ─── Base de datos ────────────────────────────────────────────────────────────
# Si se define, se usa PostgreSQL vía dj-database-url. Si se deja vacío/ausente, SQLite.
# Django 5.2 requiere Postgres 14+ (el de PythonAnywhere es 12, incompatible): usar un
# Postgres externo con versión 14+, p. ej. Neon (ver docs/migracion_postgres.md).
# DATABASE_URL=postgresql://usuario:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Seguridad HTTPS (producción) ─────────────────────────────────────────────
# Gated por entorno: se aplican solo si se activan aquí (default seguro-pero-off
# para no romper el deploy actual). Actívalos cuando el servidor sirva HTTPS.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
